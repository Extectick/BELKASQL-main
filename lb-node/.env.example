# Copy this file to:
#   lb-node/env/cloud-lb-a.env
#   lb-node/env/cloud-lb-b.env
#
# Change MASTER/BACKUP role, priority and peer IP between the two LB hosts.

COMPOSE_PROJECT_NAME=cloud-lb-a
BELKA_NETWORK_NAME=belkasql_belka-net

LB_CONTAINER_NAME=cloud-lb-a
LB_HOSTNAME=cloud-lb-a
LB_NAME=cloud-lb-a

# Real IP of this load balancer host inside the cloud/private network.
LB_IP=10.10.30.31

# Keepalived role.
# cloud-lb-a usually runs MASTER, cloud-lb-b runs BACKUP.
KEEPALIVED_STATE=MASTER
KEEPALIVED_PRIORITY=150
KEEPALIVED_PEER_IP=10.10.30.32
KEEPALIVED_VIP=10.10.30.30
KEEPALIVED_AUTH_PASS=replace-with-keepalived-password
# Set false for a single non-VIP cloud load balancer.
KEEPALIVED_ENABLED=true

# Public or internal DB domains clients will use.
DB_WRITE_DOMAIN=db-write.example.com
DB_READ_DOMAIN=db-read.example.com

# Real DB node addresses reachable from the LB host.
# Add future nodes here only; HAProxy backends are generated from this list.
DB_NODES=city-a=10.10.10.11 city-b=10.10.20.11

# Published ports on the LB host.
LB_WRITE_PUBLISHED_PORT=5000
LB_READ_PUBLISHED_PORT=5001
LB_METRICS_PUBLISHED_PORT=8404

# Monitoring and centralized log shipping.
NODE_EXPORTER_CONTAINER_NAME=cloud-lb-a-node-exporter
NODE_EXPORTER_PUBLISHED_PORT=9100
NODE_EXPORTER_IP=172.28.0.79
PROMTAIL_CONTAINER_NAME=cloud-lb-a-promtail
PROMTAIL_NODE_LABEL=cloud-lb-a
PROMTAIL_ROLE_LABEL=lb-node
PROMTAIL_IP=172.28.0.80
LOKI_PUSH_URL=http://monitoring.example.com:3100/loki/api/v1/push
