# Copy this file to a real env file, for example:
#   db-node/env/city-a.env
#   db-node/env/city-b.env
#
# This template describes one DB server.
# Use different values on the second DB node.

# docker compose project name on this host
COMPOSE_PROJECT_NAME=city-a

# Shared Docker network name.
# Keep the same value on all hosts if you simulate locally.
# On separate servers the compose file still expects a network with this name.
BELKA_NETWORK_NAME=belkasql_belka-net

# etcd timing tuned for WAN / inter-city latency.
# For real geo deployment these values are intentionally conservative.
ETCD_HEARTBEAT_INTERVAL=2000
ETCD_ELECTION_TIMEOUT=10000
ETCD_CLIENT_PUBLISHED_PORT=2379

# Local etcd node identity on this DB server.
ETCD_CONTAINER_NAME=etcd-city-a
ETCD_HOSTNAME=etcd-city-a
ETCD_NAME=etcd-city-a

# Real host/IP that other servers can reach.
# For production set the real server IP or internal DNS name.
ETCD_ADVERTISE_HOST=10.10.10.11
ETCD_IP=172.28.0.23

# Must be identical on all three etcd nodes.
ETCD_CLUSTER_TOKEN=belka-etcd-cluster

# Full 3-node etcd cluster definition.
# Must be byte-for-byte identical on city-a, city-b and cloud-control.
ETCD_INITIAL_CLUSTER=etcd-city-a=http://10.10.10.11:2380,etcd-city-b=http://10.10.20.11:2380,etcd-cloud=http://10.10.30.10:2380

# PostgreSQL/Patroni node identity.
DB_CONTAINER_NAME=city-a-db
DB_HOSTNAME=city-a-db
DB_IP=172.28.0.21
NODE_NAME=city-a-db

# Real address peers and load balancers use to reach Patroni/PostgreSQL on this node.
NODE_API_HOST=10.10.10.11
NODE_PG_HOST=10.10.10.11
PATRONI_SCOPE=belka-ha

# Host ports peers can use to reach Patroni REST and PgBouncer on this DB node.
# On real separate servers these are usually 8008/6432.
# In the single-host lab keep host ports unique per node.
PATRONI_API_PUBLISHED_PORT=8008
PGBOUNCER_PUBLISHED_PORT=6432

# Local HAProxy container that gives city-local access.
LOCAL_LB_CONTAINER_NAME=city-a-local-lb
LOCAL_LB_HOSTNAME=city-a-local-lb
LOCAL_LB_IP=172.28.0.22

# Host ports published on this server for local city access.
# Use 5000/5001 on real separate servers if no conflict exists.
LOCAL_LB_WRITE_PUBLISHED_PORT=5000
LOCAL_LB_READ_PUBLISHED_PORT=5001

# Monitoring and log shipping from this DB node.
POSTGRES_EXPORTER_CONTAINER_NAME=city-a-postgres-exporter
POSTGRES_EXPORTER_PUBLISHED_PORT=9187
POSTGRES_EXPORTER_IP=172.28.0.73
NODE_EXPORTER_CONTAINER_NAME=city-a-node-exporter
NODE_EXPORTER_PUBLISHED_PORT=9100
NODE_EXPORTER_IP=172.28.0.74
PROMTAIL_CONTAINER_NAME=city-a-promtail
PROMTAIL_NODE_LABEL=city-a
PROMTAIL_ROLE_LABEL=db-node
PROMTAIL_IP=172.28.0.75
LOKI_PUSH_URL=http://monitoring.example.com:3100/loki/api/v1/push

# Container hostnames used by local HAProxy inside the compose project.
LOCAL_DB_HOST=city-a-db
REMOTE_DB_HOST=10.10.20.11

# City-local DNS alias clients may use for write access near this city.
LOCAL_DB_DOMAIN=db-city-a.example.internal

# All Patroni nodes use the same three etcd endpoints.
# On each DB host, point the colocated etcd entry at the compose-local alias.
ETCD_HOST_1=etcd-city-a
ETCD_HOST_2=10.10.20.11
ETCD_HOST_3=10.10.30.10

# pgBackRest stanza and backup endpoint.
BACKREST_STANZA=belka
BACKREST_S3_BUCKET=belka-pgbackrest
BACKREST_S3_ENDPOINT=10.10.30.20
BACKREST_S3_KEY=replace-with-minio-access-key
BACKREST_S3_SECRET=replace-with-minio-secret-key
BACKREST_S3_REGION=us-east-1

# PostgreSQL credentials.
# Replace all passwords before production deployment.
POSTGRES_SUPERUSER_PASSWORD=replace-with-strong-postgres-password
REPLICATION_PASSWORD=replace-with-strong-replication-password
APP_USER_PASSWORD=replace-with-strong-app-password
