# Copy this file to db-node/env/<node>.env for an additional PostgreSQL node
# that should join an existing Patroni cluster without adding another etcd
# member. Use with:
#   docker compose --env-file env/<node>.env -f docker-compose.replica.yml up -d --build

COMPOSE_PROJECT_NAME=city-c
BELKA_NETWORK_NAME=belkasql_belka-net
INTERNAL_BIND_IP=10.77.0.4

DB_CONTAINER_NAME=city-c-db
DB_HOSTNAME=city-c-db
DB_IP=172.28.0.31
NODE_NAME=city-c-db
NODE_API_HOST=10.77.0.4
NODE_PG_HOST=10.77.0.4
PATRONI_SCOPE=belka-ha
PATRONI_API_PUBLISHED_PORT=8008
PGBOUNCER_PUBLISHED_PORT=6432

LOCAL_LB_CONTAINER_NAME=city-c-local-lb
LOCAL_LB_HOSTNAME=city-c-local-lb
LOCAL_LB_IP=172.28.0.32
LOCAL_LB_WRITE_PUBLISHED_PORT=5000
LOCAL_LB_READ_PUBLISHED_PORT=5001

POSTGRES_EXPORTER_CONTAINER_NAME=city-c-postgres-exporter
POSTGRES_EXPORTER_PUBLISHED_PORT=9187
POSTGRES_EXPORTER_IP=172.28.0.83
NODE_EXPORTER_CONTAINER_NAME=city-c-node-exporter
NODE_EXPORTER_PUBLISHED_PORT=9100
NODE_EXPORTER_IP=172.28.0.84
PROMTAIL_CONTAINER_NAME=city-c-promtail
PROMTAIL_NODE_LABEL=city-c
PROMTAIL_ROLE_LABEL=db-node
PROMTAIL_IP=172.28.0.85
LOKI_PUSH_URL=http://10.77.0.1:3100/loki/api/v1/push

LOCAL_DB_HOST=city-c-db
REMOTE_DB_HOST=10.77.0.2
LOCAL_DB_DOMAIN=db-city-c.internal

# Existing etcd endpoints. Do not add a fourth etcd node unless you are
# intentionally redesigning the etcd quorum.
ETCD_HOST_1=10.77.0.1
ETCD_HOST_2=10.77.0.2
ETCD_HOST_3=10.77.0.3

BACKREST_STANZA=belka
BACKREST_S3_BUCKET=replace-with-s3-bucket
BACKREST_S3_ENDPOINT=replace-with-s3-endpoint
BACKREST_S3_KEY=replace-with-s3-access-key
BACKREST_S3_SECRET=replace-with-s3-secret-key
BACKREST_S3_REGION=us-east-1
BACKREST_S3_PORT=9000
BACKREST_S3_VERIFY_TLS=n

POSTGRES_SUPERUSER_PASSWORD=replace-with-strong-postgres-password
REPLICATION_PASSWORD=replace-with-strong-replication-password
APP_USER_PASSWORD=replace-with-strong-app-password
