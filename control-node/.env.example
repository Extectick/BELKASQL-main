# Copy this file to:
#   control-node/env/cloud-control.env
#
# This template describes the third etcd node.

COMPOSE_PROJECT_NAME=cloud-control
BELKA_NETWORK_NAME=belkasql_belka-net

# etcd timing tuned for WAN / inter-city latency.
ETCD_HEARTBEAT_INTERVAL=2000
ETCD_ELECTION_TIMEOUT=10000
ETCD_CLIENT_PUBLISHED_PORT=2379

ETCD_CONTAINER_NAME=etcd-cloud
ETCD_HOSTNAME=etcd-cloud
ETCD_NAME=etcd-cloud

# Real cloud host/IP reachable from both DB cities.
ETCD_ADVERTISE_HOST=10.10.30.10
ETCD_IP=172.28.0.13

# Must match values on both DB nodes.
ETCD_CLUSTER_TOKEN=belka-etcd-cluster
ETCD_INITIAL_CLUSTER=etcd-city-a=http://10.10.10.11:2380,etcd-city-b=http://10.10.20.11:2380,etcd-cloud=http://10.10.30.10:2380

# Monitoring and centralized log shipping.
NODE_EXPORTER_CONTAINER_NAME=cloud-control-node-exporter
NODE_EXPORTER_PUBLISHED_PORT=9100
NODE_EXPORTER_IP=172.28.0.71
PROMTAIL_CONTAINER_NAME=cloud-control-promtail
PROMTAIL_NODE_LABEL=cloud-control
PROMTAIL_ROLE_LABEL=control-node
PROMTAIL_IP=172.28.0.72
LOKI_PUSH_URL=http://monitoring.example.com:3100/loki/api/v1/push
