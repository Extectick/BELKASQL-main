# Copy this file to:
#   storage-node/env/minio-primary.env
#   storage-node/env/minio-secondary.env
#
# This template can be used for either storage host.
# Replace names, host IPs and credentials for the second MinIO node.

COMPOSE_PROJECT_NAME=minio-primary
BELKA_NETWORK_NAME=belkasql_belka-net

MINIO_CONTAINER_NAME=minio-primary
MINIO_HOSTNAME=minio-primary
MINIO_IP=172.28.0.41

# Replace with strong access credentials.
MINIO_ROOT_USER=replace-with-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-minio-secret-key

# Console URL users open in a browser for this MinIO host.
MINIO_BROWSER_REDIRECT_URL=https://backup-primary.example.com:9001
MINIO_API_PUBLISHED_PORT=9000
MINIO_CONSOLE_PUBLISHED_PORT=9001

# Monitoring and centralized log shipping.
NODE_EXPORTER_CONTAINER_NAME=minio-primary-node-exporter
NODE_EXPORTER_PUBLISHED_PORT=9100
NODE_EXPORTER_IP=172.28.0.83
PROMTAIL_CONTAINER_NAME=minio-primary-promtail
PROMTAIL_NODE_LABEL=minio-primary
PROMTAIL_ROLE_LABEL=storage-node
PROMTAIL_IP=172.28.0.84
LOKI_PUSH_URL=http://monitoring.example.com:3100/loki/api/v1/push

# Admin and mirror helpers used only when storage-node is deployed with --with-admin.
# In the single-MinIO DB-ingress production profile these can stay unset or be left as placeholders.
MINIO_ADMIN_CONTAINER_NAME=minio-admin
MINIO_ADMIN_HOSTNAME=minio-admin
MINIO_ADMIN_IP=172.28.0.43
MINIO_MIRROR_CONTAINER_NAME=minio-mirror
MINIO_MIRROR_HOSTNAME=minio-mirror
MINIO_MIRROR_IP=172.28.0.44

# Primary/secondary pair definition used only with --with-admin replication helpers.
# On the primary node MINIO_PRIMARY_HOST is this server and MINIO_SECONDARY_HOST is the DR server.
# On the secondary node invert the hostnames and credentials accordingly.
MINIO_PRIMARY_HOST=10.10.30.20
MINIO_PRIMARY_ROOT_USER=replace-with-primary-access-key
MINIO_PRIMARY_ROOT_PASSWORD=replace-with-primary-secret-key
MINIO_SECONDARY_HOST=10.20.30.20
MINIO_SECONDARY_ROOT_USER=replace-with-secondary-access-key
MINIO_SECONDARY_ROOT_PASSWORD=replace-with-secondary-secret-key

# Bucket used by pgBackRest.
PGBACKREST_S3_BUCKET=belka-pgbackrest
